{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Asteria",
  "version": "0.1.0",
  "identifier": "com.daniel.asteria",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Asteria",
        "width": 800,
        "height": 600,
        "resizable": true,
        "decorations": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../sidecars/python-ai/asteria_sidecar.py": "sidecars/python-ai/asteria_sidecar.py",
      "../sidecars/python-ai/image_ops/__init__.py": "sidecars/python-ai/image_ops/__init__.py",
      "../sidecars/python-ai/image_ops/background_removal.py": "sidecars/python-ai/image_ops/background_removal.py",
      "../sidecars/python-ai/image_ops/enhancement.py": "sidecars/python-ai/image_ops/enhancement.py",
      "../sidecars/python-ai/image_ops/format_conversion.py": "sidecars/python-ai/image_ops/format_conversion.py",
      "../sidecars/python-ai/image_ops/model_manager.py": "sidecars/python-ai/image_ops/model_manager.py",
      "../sidecars/python-ai/image_ops/resize.py": "sidecars/python-ai/image_ops/resize.py",
      "../sidecars/python-ai/image_ops/upscale.py": "sidecars/python-ai/image_ops/upscale.py",
      "../sidecars/python-ai/image_ops/utils.py": "sidecars/python-ai/image_ops/utils.py"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:asteria.db"
      ]
    }
  }
}
